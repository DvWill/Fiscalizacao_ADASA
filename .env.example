# Vercel Functions (Node)
NEON_DATABASE_URL=postgresql://user:password@host/database?sslmode=require&channel_binding=require
# Obrigatorio em producao para as APIs serverless e Quarkus.
API_TOKEN=
# Opcional: use true somente se o certificado do banco for validado pelo runtime.
PG_SSL_REJECT_UNAUTHORIZED=false
# Opcional: login por sessao (ativa tela de login quando definido)
AUTH_LOGIN=seu_login
AUTH_PASSWORD=sua_senha_forte
AUTH_SESSION_SECRET=sua_chave_secreta_longa
AUTH_SESSION_TTL_SECONDS=43200
# Opcional: lista de origens separadas por virgula
CORS_ALLOWED_ORIGINS=https://seu-frontend.com,https://outro-dominio.com
# Opcional: somente para ambientes controlados fora de producao.
# CORS_ALLOW_ALL=false
# CORS_ALLOW_ALL_IN_PRODUCTION=false

# Quarkus (Java)
APP_AUTH_REQUIRED=true
JDBC_DATABASE_URL=jdbc:postgresql://host:5432/database?sslmode=require
DB_USER=postgres
DB_PASSWORD=postgres
MIRROR_ENABLED=false
MIRROR_JDBC_DATABASE_URL=
MIRROR_DB_USER=sa
MIRROR_DB_PASSWORD=sa
